# Configuração de conexão com o Postgres do SIGTAP
# Copie este arquivo para ".env" (sem o .example) e ajuste se necessário.
# Os valores abaixo são os mesmos definidos no docker-compose.yml do
# projeto import-sigtap-prototipo.

SIGTAP_DB_HOST=localhost
SIGTAP_DB_PORT=5432
SIGTAP_DB_NAME=sigtap
SIGTAP_DB_USER=sigtap
SIGTAP_DB_PASSWORD=sigtap
